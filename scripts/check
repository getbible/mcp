#!/usr/bin/env bash
set -Eeuo pipefail

PROJECT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
PYTHON="${PROJECT_DIR}/.venv/bin/python"
export PIP_NO_CACHE_DIR=1

if [[ ! -x ${PYTHON} ]]; then
    echo "Create .venv and install requirements-dev.txt plus the project first." >&2
    exit 1
fi

cd "${PROJECT_DIR}"
"${PYTHON}" -m ruff check .
"${PYTHON}" -m mypy src
"${PYTHON}" -m pytest
"${PYTHON}" -m build
